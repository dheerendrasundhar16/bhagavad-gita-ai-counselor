# ─────────────────────────────────────────────────────────────────────────────
# Bhagavad Gita AI Counselor — Environment Configuration
#
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it is listed in .gitignore.
# On Render, set these values in the service's Environment tab instead.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Required. Get your key at: https://aistudio.google.com/app/apikey
# Backend service only — NEVER exposed to the frontend.
GEMINI_API_KEY=your_gemini_api_key_here

# Accepted alias (pick one):
# GOOGLE_API_KEY=your_gemini_api_key_here

# ── FastAPI Backend ───────────────────────────────────────────────────────────
# Local dev defaults (Render sets PORT automatically)
HOST=127.0.0.1
PORT=8000

# ── ChromaDB Vector Store ─────────────────────────────────────────────────────
# Path to the persistent vector store directory (relative to project root)
CHROMA_DB_PATH=./data/chromadb

# ── Streamlit Frontend ────────────────────────────────────────────────────────
# URL of the FastAPI backend the Streamlit app will call.
#
# Local dev:
BACKEND_URL=http://127.0.0.1:8000
#
# Production (Render):
# After deploying the backend service on Render, paste its public URL here
# and set it in the frontend service's Environment tab in the Render dashboard.
# BACKEND_URL=https://gita-counselor-backend.onrender.com
